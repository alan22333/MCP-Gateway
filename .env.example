# MCP Gateway environment variables
# Copy to .env and adjust for your deployment
# Viper automatically maps MCP_* env vars to config.yaml keys

# Server
MCP_SERVER_PORT=8080
MCP_SERVER_MAX_BODY_BYTES=1048576

# Database
MCP_DATABASE_DRIVER=sqlite
MCP_DATABASE_DSN=gateway.db

# Cache (Redis optional, defaults to in-memory)
MCP_CACHE_ENABLED=true
MCP_CACHE_REDIS_ADDR=
MCP_CACHE_REDIS_PASSWORD=
MCP_CACHE_REDIS_DB=0
MCP_CACHE_TTL=60

# Rate limit
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_REQUESTS_PER_SECOND=5
MCP_RATE_LIMIT_BURST=10

# Circuit breaker
MCP_CIRCUIT_BREAKER_ENABLED=true
MCP_CIRCUIT_BREAKER_MAX_FAILURES=5
MCP_CIRCUIT_BREAKER_TIMEOUT=30
MCP_CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=1

# Auth (disabled by default for demo)
MCP_AUTH_ENABLED=false

# Config file path (if not using config.yaml)
# MCP_GATEWAY_CONFIG=/etc/mcp-gateway/config.yaml
